{
  "source": {
    "name": "cast64",
    "base_url": "https://cast64.com/hexagrams/{number}",
    "fetched_at": "2026-03-19",
    "notes": "Classical guaci and yaoci extracted from public hexagram pages."
  },
  "hexagrams": {
    "1": {
      "number": 1,
      "gua_ci": "元，亨，利，贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "潜龙勿用。"
        },
        "2": {
          "label": "九二",
          "text": "见龙在田，利见大人。"
        },
        "3": {
          "label": "九三",
          "text": "君子终日乾乾，夕惕若，厉无咎。"
        },
        "4": {
          "label": "九四",
          "text": "或跃在渊，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "飞龙在天，利见大人。"
        },
        "6": {
          "label": "上九",
          "text": "亢龙有悔。"
        }
      },
      "special": {
        "label": "用九",
        "text": "见群龙无首，吉。"
      },
      "source_url": "https://cast64.com/hexagrams/1"
    },
    "2": {
      "number": 2,
      "gua_ci": "元，亨，利牝马之贞。君子有攸往，先迷后得主，利。西南得朋，东北丧朋。安贞，吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "履霜，坚冰至。"
        },
        "2": {
          "label": "六二",
          "text": "直，方，大，不习无不利。"
        },
        "3": {
          "label": "六三",
          "text": "含章可贞。或从王事，无成有终。"
        },
        "4": {
          "label": "六四",
          "text": "括囊，无咎无誉。"
        },
        "5": {
          "label": "六五",
          "text": "黄裳，元吉。"
        },
        "6": {
          "label": "上六",
          "text": "龙战于野，其血玄黄。"
        }
      },
      "special": {
        "label": "用六",
        "text": "利永贞。"
      },
      "source_url": "https://cast64.com/hexagrams/2"
    },
    "3": {
      "number": 3,
      "gua_ci": "元，亨，利，贞，勿用，有攸往，利建侯。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "磐桓；利居贞，利建侯。"
        },
        "2": {
          "label": "六二",
          "text": "屯如邅如，乘马班如。匪寇婚媾，女子贞不字，十年乃字。"
        },
        "3": {
          "label": "六三",
          "text": "即鹿无虞，惟入于林中，君子几不如舍，往吝。"
        },
        "4": {
          "label": "六四",
          "text": "乘马班如，求婚媾，往吉，无不利。"
        },
        "5": {
          "label": "九五",
          "text": "屯其膏，小贞吉，大贞凶。"
        },
        "6": {
          "label": "上六",
          "text": "乘马班如，泣血涟如。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/3"
    },
    "4": {
      "number": 4,
      "gua_ci": "亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "发蒙，利用刑人，用说桎梏，以往吝。"
        },
        "2": {
          "label": "九二",
          "text": "包蒙吉，纳妇吉，子克家。"
        },
        "3": {
          "label": "六三",
          "text": "勿用娶女，见金夫，不有躬，无攸利。"
        },
        "4": {
          "label": "六四",
          "text": "困蒙，吝。"
        },
        "5": {
          "label": "六五",
          "text": "童蒙，吉。"
        },
        "6": {
          "label": "上九",
          "text": "击蒙，不利为寇，利御寇。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/4"
    },
    "5": {
      "number": 5,
      "gua_ci": "有孚，光亨，贞吉。利涉大川。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "需于郊，利用恒，无咎。"
        },
        "2": {
          "label": "九二",
          "text": "需于沙，小有言，终吉。"
        },
        "3": {
          "label": "九三",
          "text": "需于泥，致寇至。"
        },
        "4": {
          "label": "六四",
          "text": "需于血，出自穴。"
        },
        "5": {
          "label": "九五",
          "text": "需于酒食，贞吉。"
        },
        "6": {
          "label": "上六",
          "text": "入于穴，有不速之客三人来，敬之终吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/5"
    },
    "6": {
      "number": 6,
      "gua_ci": "有孚，窒。惕中吉。终凶。利见大人，不利涉大川。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "不永所事，小有言，终吉。"
        },
        "2": {
          "label": "九二",
          "text": "不克讼，归而逋，其邑人三百户，无眚。"
        },
        "3": {
          "label": "六三",
          "text": "食旧德，贞厉，终吉，或从王事，无成。"
        },
        "4": {
          "label": "九四",
          "text": "不克讼，复即命渝，安贞吉。"
        },
        "5": {
          "label": "九五",
          "text": "讼，元吉。"
        },
        "6": {
          "label": "上九",
          "text": "或锡之鞶带，终朝三褫之。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/6"
    },
    "7": {
      "number": 7,
      "gua_ci": "贞，丈人，吉无咎。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "师出以律，否臧凶。"
        },
        "2": {
          "label": "九二",
          "text": "在师中，吉无咎，王三锡命。"
        },
        "3": {
          "label": "六三",
          "text": "师或舆尸，凶。"
        },
        "4": {
          "label": "六四",
          "text": "师左次，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "田有禽，利执言，无咎。长子帅师，弟子舆尸，贞凶。"
        },
        "6": {
          "label": "上六",
          "text": "大君有命，开国承家，小人勿用。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/7"
    },
    "8": {
      "number": 8,
      "gua_ci": "吉。原筮元永贞，无咎。不宁方来，后夫凶。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "有孚，比之，无咎。有孚盈缶，终来有他，吉。"
        },
        "2": {
          "label": "六二",
          "text": "比之自内，贞吉。"
        },
        "3": {
          "label": "六三",
          "text": "比之匪人。"
        },
        "4": {
          "label": "六四",
          "text": "外比之，贞吉。"
        },
        "5": {
          "label": "九五",
          "text": "显比，王用三驱，失前禽。邑人不诫，吉。"
        },
        "6": {
          "label": "上六",
          "text": "比之无首，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/8"
    },
    "9": {
      "number": 9,
      "gua_ci": "亨。密云不雨，自我西郊。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "复自道，何其咎，吉。"
        },
        "2": {
          "label": "九二",
          "text": "牵复，吉。"
        },
        "3": {
          "label": "九三",
          "text": "舆说辐，夫妻反目。"
        },
        "4": {
          "label": "六四",
          "text": "有孚，血去惕出，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "有孚挛如，富以其邻。"
        },
        "6": {
          "label": "上九",
          "text": "既雨既处，尚德载，妇贞厉。月几望，君子征凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/9"
    },
    "10": {
      "number": 10,
      "gua_ci": "履虎尾，不咥人，亨。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "素履，往无咎。"
        },
        "2": {
          "label": "九二",
          "text": "履道坦坦，幽人贞吉。"
        },
        "3": {
          "label": "六三",
          "text": "眇能视，跛能履，履虎尾，咥人，凶。武人为于大君。"
        },
        "4": {
          "label": "九四",
          "text": "履虎尾，愬愬终吉。"
        },
        "5": {
          "label": "九五",
          "text": "夬履，贞厉。"
        },
        "6": {
          "label": "上九",
          "text": "视履考祥，其旋元吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/10"
    },
    "11": {
      "number": 11,
      "gua_ci": "小往大来，吉亨。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "拔茅茹，以其汇，征吉。"
        },
        "2": {
          "label": "九二",
          "text": "包荒，用冯河，不遐遗，朋亡，得尚于中行。"
        },
        "3": {
          "label": "九三",
          "text": "无平不陂，无往不复，艰贞无咎。勿恤其孚，于食有福。"
        },
        "4": {
          "label": "六四",
          "text": "翩翩不富，以其邻，不戒以孚。"
        },
        "5": {
          "label": "六五",
          "text": "帝乙归妹，以祉元吉。"
        },
        "6": {
          "label": "上六",
          "text": "城复于隍，勿用师。自邑告命，贞吝。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/11"
    },
    "12": {
      "number": 12,
      "gua_ci": "否之匪人，不利君子贞，大往小来。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "拔茅茹，以其汇，贞吉亨。"
        },
        "2": {
          "label": "六二",
          "text": "包承，小人吉，大人否亨。"
        },
        "3": {
          "label": "六三",
          "text": "包羞。"
        },
        "4": {
          "label": "九四",
          "text": "有命无咎，畴离祉。"
        },
        "5": {
          "label": "九五",
          "text": "休否，大人吉。其亡其亡，系于苞桑。"
        },
        "6": {
          "label": "上九",
          "text": "倾否，先否后喜。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/12"
    },
    "13": {
      "number": 13,
      "gua_ci": "同人于野，亨。利涉大川，利君子贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "同人于门，无咎。"
        },
        "2": {
          "label": "六二",
          "text": "同人于宗，吝。"
        },
        "3": {
          "label": "九三",
          "text": "伏戎于莽，升其高陵，三岁不兴。"
        },
        "4": {
          "label": "九四",
          "text": "乘其墉，弗克攻，吉。"
        },
        "5": {
          "label": "九五",
          "text": "同人，先号咷而后笑。大师克相遇。"
        },
        "6": {
          "label": "上九",
          "text": "同人于郊，无悔。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/13"
    },
    "14": {
      "number": 14,
      "gua_ci": "元亨。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "无交害，匪咎，艰则无咎。"
        },
        "2": {
          "label": "九二",
          "text": "大车以载，有攸往，无咎。"
        },
        "3": {
          "label": "九三",
          "text": "公用亨于天子，小人弗克。"
        },
        "4": {
          "label": "九四",
          "text": "匪其彭，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "厥孚交如，威如；吉。"
        },
        "6": {
          "label": "上九",
          "text": "自天佑之，吉无不利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/14"
    },
    "15": {
      "number": 15,
      "gua_ci": "亨，君子有终。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "谦谦君子，用涉大川，吉。"
        },
        "2": {
          "label": "六二",
          "text": "鸣谦，贞吉。"
        },
        "3": {
          "label": "九三",
          "text": "劳谦君子，有终吉。"
        },
        "4": {
          "label": "六四",
          "text": "无不利，撝谦。"
        },
        "5": {
          "label": "六五",
          "text": "不富，以其邻，利用侵伐，无不利。"
        },
        "6": {
          "label": "上六",
          "text": "鸣谦，利用行师，征邑国。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/15"
    },
    "16": {
      "number": 16,
      "gua_ci": "利建侯行师。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "鸣豫，凶。"
        },
        "2": {
          "label": "六二",
          "text": "介于石，不终日，贞吉。"
        },
        "3": {
          "label": "六三",
          "text": "盱豫，悔。迟有悔。"
        },
        "4": {
          "label": "九四",
          "text": "由豫，大有得。勿疑。朋盍簪。"
        },
        "5": {
          "label": "六五",
          "text": "贞疾，恒不死。"
        },
        "6": {
          "label": "上六",
          "text": "冥豫，成有渝，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/16"
    },
    "17": {
      "number": 17,
      "gua_ci": "随，元亨，利贞。无咎。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "官有渝，贞吉。出门交有功。"
        },
        "2": {
          "label": "六二",
          "text": "系小子，失丈夫。"
        },
        "3": {
          "label": "六三",
          "text": "系丈夫，失小子。随有求得，利居贞。"
        },
        "4": {
          "label": "九四",
          "text": "随有获，贞凶。有孚在道，以明，何咎。"
        },
        "5": {
          "label": "九五",
          "text": "孚于嘉，吉。"
        },
        "6": {
          "label": "上六",
          "text": "拘系之，乃从维之。王用亨于西山。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/17"
    },
    "18": {
      "number": 18,
      "gua_ci": "蛊，元亨。利涉大川。先甲三日，后甲三日。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "干父之蛊，有子，考无咎，厉终吉。"
        },
        "2": {
          "label": "九二",
          "text": "干母之蛊，不可贞。"
        },
        "3": {
          "label": "九三",
          "text": "干父之蛊，小有悔，无大咎。"
        },
        "4": {
          "label": "六四",
          "text": "裕父之蛊，往见吝。"
        },
        "5": {
          "label": "六五",
          "text": "干父之蛊，用誉。"
        },
        "6": {
          "label": "上九",
          "text": "不事王侯，高尚其事。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/18"
    },
    "19": {
      "number": 19,
      "gua_ci": "临，元亨，利贞。至于八月有凶。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "咸临，贞吉。"
        },
        "2": {
          "label": "九二",
          "text": "咸临，吉无不利。"
        },
        "3": {
          "label": "六三",
          "text": "甘临，无攸利。既忧之，无咎。"
        },
        "4": {
          "label": "六四",
          "text": "至临，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "知临，大君之宜，吉。"
        },
        "6": {
          "label": "上六",
          "text": "敦临，吉无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/19"
    },
    "20": {
      "number": 20,
      "gua_ci": "观。盥而不荐，有孚颙若。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "童观，小人无咎，君子吝。"
        },
        "2": {
          "label": "六二",
          "text": "窥观，利女贞。"
        },
        "3": {
          "label": "六三",
          "text": "观我生，进退。"
        },
        "4": {
          "label": "六四",
          "text": "观国之光，利用宾于王。"
        },
        "5": {
          "label": "九五",
          "text": "观我生，君子无咎。"
        },
        "6": {
          "label": "上九",
          "text": "观其生，君子无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/20"
    },
    "21": {
      "number": 21,
      "gua_ci": "噬嗑，亨。利用狱。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "屦校灭趾，无咎。"
        },
        "2": {
          "label": "六二",
          "text": "噬肤灭鼻，无咎。"
        },
        "3": {
          "label": "六三",
          "text": "噬腊肉，遇毒；小吝，无咎。"
        },
        "4": {
          "label": "九四",
          "text": "噬干胏，得金矢，利艰贞，吉。"
        },
        "5": {
          "label": "六五",
          "text": "噬干肉，得黄金，贞厉，无咎。"
        },
        "6": {
          "label": "上九",
          "text": "何校灭耳，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/21"
    },
    "22": {
      "number": 22,
      "gua_ci": "贲，亨。小利有攸往。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "贲其趾，舍车而徒。"
        },
        "2": {
          "label": "六二",
          "text": "贲其须。"
        },
        "3": {
          "label": "九三",
          "text": "贲如濡如，永贞吉。"
        },
        "4": {
          "label": "六四",
          "text": "贲如皤如，白马翰如，匪寇婚媾。"
        },
        "5": {
          "label": "六五",
          "text": "贲于丘园，束帛戋戋，吝，终吉。"
        },
        "6": {
          "label": "上九",
          "text": "白贲，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/22"
    },
    "23": {
      "number": 23,
      "gua_ci": "剥，不利有攸往。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "剥床以足，蔑贞凶。"
        },
        "2": {
          "label": "六二",
          "text": "剥床以辨，蔑贞凶。"
        },
        "3": {
          "label": "六三",
          "text": "剥之，无咎。"
        },
        "4": {
          "label": "六四",
          "text": "剥床以肤，凶。"
        },
        "5": {
          "label": "六五",
          "text": "贯鱼，以宫人宠，无不利。"
        },
        "6": {
          "label": "上九",
          "text": "硕果不食，君子得舆，小人剥庐。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/23"
    },
    "24": {
      "number": 24,
      "gua_ci": "复，亨。出入无疾，朋来无咎。反复其道，七日来复，利有攸往。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "不远复，无祗悔，元吉。"
        },
        "2": {
          "label": "六二",
          "text": "休复，吉。"
        },
        "3": {
          "label": "六三",
          "text": "频复，厉无咎。"
        },
        "4": {
          "label": "六四",
          "text": "中行独复。"
        },
        "5": {
          "label": "六五",
          "text": "敦复，无悔。"
        },
        "6": {
          "label": "上六",
          "text": "迷复，凶，有灾眚。用行师，终有大败，以其国君，凶；至于十年，不克征。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/24"
    },
    "25": {
      "number": 25,
      "gua_ci": "无妄，元亨利贞。其匪正有眚，不利有攸往。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "无妄，往吉。"
        },
        "2": {
          "label": "六二",
          "text": "不耕获，不菑畲，则利有攸往。"
        },
        "3": {
          "label": "六三",
          "text": "无妄之灾，或系之牛，行人之得，邑人之灾。"
        },
        "4": {
          "label": "九四",
          "text": "可贞，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "无妄之疾，勿药有喜。"
        },
        "6": {
          "label": "上九",
          "text": "无妄，行有眚，无攸利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/25"
    },
    "26": {
      "number": 26,
      "gua_ci": "大畜，利贞，不家食吉，利涉大川。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "有厉利已。"
        },
        "2": {
          "label": "九二",
          "text": "舆说輹。"
        },
        "3": {
          "label": "九三",
          "text": "良马逐，利艰贞。曰闲舆卫，利有攸往。"
        },
        "4": {
          "label": "六四",
          "text": "童牛之牿，元吉。"
        },
        "5": {
          "label": "六五",
          "text": "豮豕之牙，吉。"
        },
        "6": {
          "label": "上九",
          "text": "何天之衢，亨。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/26"
    },
    "27": {
      "number": 27,
      "gua_ci": "颐，贞吉。观颐，自求口实。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "舍尔灵龟，观我朵颐，凶。"
        },
        "2": {
          "label": "六二",
          "text": "颠颐，拂经，于丘颐，征凶。"
        },
        "3": {
          "label": "六三",
          "text": "拂颐，贞凶，十年勿用，无攸利。"
        },
        "4": {
          "label": "六四",
          "text": "颠颐吉，虎视眈眈，其欲逐逐，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "拂经，居贞吉，不可涉大川。"
        },
        "6": {
          "label": "上九",
          "text": "由颐，厉吉，利涉大川。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/27"
    },
    "28": {
      "number": 28,
      "gua_ci": "大过，栋桡，利有攸往，亨。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "藉用白茅，无咎。"
        },
        "2": {
          "label": "九二",
          "text": "枯杨生稊，老夫得其女妻，无不利。"
        },
        "3": {
          "label": "九三",
          "text": "栋桡，凶。"
        },
        "4": {
          "label": "九四",
          "text": "栋隆，吉；有它吝。"
        },
        "5": {
          "label": "九五",
          "text": "枯杨生华，老妇得士夫，无咎无誉。"
        },
        "6": {
          "label": "上六",
          "text": "过涉灭顶，凶，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/28"
    },
    "29": {
      "number": 29,
      "gua_ci": "习坎，有孚，维心亨，行有尚。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "习坎，入于坎窞，凶。"
        },
        "2": {
          "label": "九二",
          "text": "坎有险，求小得。"
        },
        "3": {
          "label": "六三",
          "text": "来之坎坎，险且枕，入于坎窞，勿用。"
        },
        "4": {
          "label": "六四",
          "text": "樽酒簋贰，用缶，纳约自牖，终无咎。"
        },
        "5": {
          "label": "九五",
          "text": "坎不盈，祗既平，无咎。"
        },
        "6": {
          "label": "上六",
          "text": "系用徽纆，寘于丛棘，三岁不得，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/29"
    },
    "30": {
      "number": 30,
      "gua_ci": "离，利贞，亨。畜牝牛，吉。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "履错然，敬之无咎。"
        },
        "2": {
          "label": "六二",
          "text": "黄离，元吉。"
        },
        "3": {
          "label": "九三",
          "text": "日昃之离，不鼓缶而歌，则大耋之嗟，凶。"
        },
        "4": {
          "label": "九四",
          "text": "突如其来如，焚如，死如，弃如。"
        },
        "5": {
          "label": "六五",
          "text": "出涕沱若，戚嗟若，吉。"
        },
        "6": {
          "label": "上九",
          "text": "王用出征，有嘉折首，获匪其丑，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/30"
    },
    "31": {
      "number": 31,
      "gua_ci": "咸，亨，利贞，取女吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "咸其拇。"
        },
        "2": {
          "label": "六二",
          "text": "咸其腓，凶，居吉。"
        },
        "3": {
          "label": "九三",
          "text": "咸其股，执其随，往吝。"
        },
        "4": {
          "label": "九四",
          "text": "贞吉悔亡，憧憧往来，朋从尔思。"
        },
        "5": {
          "label": "九五",
          "text": "咸其脢，无悔。"
        },
        "6": {
          "label": "上六",
          "text": "咸其辅，颊，舌。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/31"
    },
    "32": {
      "number": 32,
      "gua_ci": "亨，无咎，利贞，利有攸往。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "浚恒，贞凶，无攸利。"
        },
        "2": {
          "label": "九二",
          "text": "悔亡。"
        },
        "3": {
          "label": "九三",
          "text": "不恒其德，或承之羞，贞吝。"
        },
        "4": {
          "label": "九四",
          "text": "田无禽。"
        },
        "5": {
          "label": "六五",
          "text": "恒其德，贞，妇人吉，夫子凶。"
        },
        "6": {
          "label": "上六",
          "text": "振恒，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/32"
    },
    "33": {
      "number": 33,
      "gua_ci": "亨，小利贞。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "遁尾，厉，勿用有攸往。"
        },
        "2": {
          "label": "六二",
          "text": "执之用黄牛之革，莫之胜说。"
        },
        "3": {
          "label": "九三",
          "text": "系遁，有疾厉，畜臣妾吉。"
        },
        "4": {
          "label": "九四",
          "text": "好遁君子吉，小人否。"
        },
        "5": {
          "label": "九五",
          "text": "嘉遁，贞吉。"
        },
        "6": {
          "label": "上九",
          "text": "肥遁，无不利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/33"
    },
    "34": {
      "number": 34,
      "gua_ci": "利贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "壮于趾，征凶，有孚。"
        },
        "2": {
          "label": "九二",
          "text": "贞吉。"
        },
        "3": {
          "label": "九三",
          "text": "小人用壮，君子用罔，贞厉。羝羊触藩，羸其角。"
        },
        "4": {
          "label": "九四",
          "text": "贞吉悔亡，藩决不羸，壮于大舆之輹。"
        },
        "5": {
          "label": "六五",
          "text": "丧羊于易，无悔。"
        },
        "6": {
          "label": "上六",
          "text": "羝羊触藩，不能退，不能遂，无攸利，艰则吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/34"
    },
    "35": {
      "number": 35,
      "gua_ci": "康侯用锡马蕃庶，昼日三接。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "晋如，摧如，贞吉。罔孚，裕无咎。"
        },
        "2": {
          "label": "六二",
          "text": "晋如，愁如，贞吉。受兹介福，于其王母。"
        },
        "3": {
          "label": "六三",
          "text": "众允，悔亡。"
        },
        "4": {
          "label": "九四",
          "text": "晋如硕鼠，贞厉。"
        },
        "5": {
          "label": "六五",
          "text": "悔亡，失得勿恤，往吉无不利。"
        },
        "6": {
          "label": "上九",
          "text": "晋其角，维用伐邑，厉吉无咎，贞吝。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/35"
    },
    "36": {
      "number": 36,
      "gua_ci": "利艰贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "明夷于飞，垂其翼。君子于行，三日不食，有攸往，主人有言。"
        },
        "2": {
          "label": "六二",
          "text": "明夷，夷于左股，用拯马壮，吉。"
        },
        "3": {
          "label": "九三",
          "text": "明夷于南狩，得其大首，不可疾贞。"
        },
        "4": {
          "label": "六四",
          "text": "入于左腹，获明夷之心，出于门庭。"
        },
        "5": {
          "label": "六五",
          "text": "箕子之明夷，利贞。"
        },
        "6": {
          "label": "上六",
          "text": "不明晦，初登于天，后入于地。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/36"
    },
    "37": {
      "number": 37,
      "gua_ci": "利女贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "闲有家，悔亡。"
        },
        "2": {
          "label": "六二",
          "text": "无攸遂，在中馈，贞吉。"
        },
        "3": {
          "label": "九三",
          "text": "家人嗃嗃，悔厉吉；妇子嘻嘻，终吝。"
        },
        "4": {
          "label": "六四",
          "text": "富家，大吉。"
        },
        "5": {
          "label": "九五",
          "text": "王假有家，勿恤吉。"
        },
        "6": {
          "label": "上九",
          "text": "有孚威如，终吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/37"
    },
    "38": {
      "number": 38,
      "gua_ci": "小事吉。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "悔亡，丧马勿逐，自复；见恶人无咎。"
        },
        "2": {
          "label": "九二",
          "text": "遇主于巷，无咎。"
        },
        "3": {
          "label": "六三",
          "text": "见舆曳，其牛掣，其人天且劓，无初有终。"
        },
        "4": {
          "label": "九四",
          "text": "睽孤，遇元夫，交孚，厉无咎。"
        },
        "5": {
          "label": "六五",
          "text": "悔亡，厥宗噬肤，往何咎。"
        },
        "6": {
          "label": "上九",
          "text": "睽孤，见豕负涂，载鬼一车，先张之弧，后说之弧，匪寇婚媾，往遇雨则吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/38"
    },
    "39": {
      "number": 39,
      "gua_ci": "利西南，不利东北；利见大人，贞吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "往蹇，来誉。"
        },
        "2": {
          "label": "六二",
          "text": "王臣蹇蹇，匪躬之故。"
        },
        "3": {
          "label": "九三",
          "text": "往蹇来反。"
        },
        "4": {
          "label": "六四",
          "text": "往蹇来连。"
        },
        "5": {
          "label": "九五",
          "text": "大蹇朋来。"
        },
        "6": {
          "label": "上六",
          "text": "往蹇来硕，吉；利见大人。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/39"
    },
    "40": {
      "number": 40,
      "gua_ci": "利西南，无所往，其来复吉。有攸往，夙吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "无咎。"
        },
        "2": {
          "label": "九二",
          "text": "田获三狐，得黄矢，贞吉。"
        },
        "3": {
          "label": "六三",
          "text": "负且乘，致寇至，贞吝。"
        },
        "4": {
          "label": "九四",
          "text": "解而拇，朋至斯孚。"
        },
        "5": {
          "label": "六五",
          "text": "君子维有解，吉；有孚于小人。"
        },
        "6": {
          "label": "上六",
          "text": "公用射隼，于高墉之上，获之，无不利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/40"
    },
    "41": {
      "number": 41,
      "gua_ci": "有孚，元吉，无咎，可贞，利有攸往？曷之用，二簋可用享。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "已事遄往，无咎，酌损之。"
        },
        "2": {
          "label": "九二",
          "text": "利贞，征凶，弗损益之。"
        },
        "3": {
          "label": "六三",
          "text": "三人行，则损一人；一人行，则得其友。"
        },
        "4": {
          "label": "六四",
          "text": "损其疾，使遄有喜，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "或益之，十朋之龟弗克违，元吉。"
        },
        "6": {
          "label": "上九",
          "text": "弗损益之，无咎，贞吉，利有攸往，得臣无家。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/41"
    },
    "42": {
      "number": 42,
      "gua_ci": "利有攸往，利涉大川。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "利用为大作，元吉，无咎。"
        },
        "2": {
          "label": "六二",
          "text": "或益之，十朋之龟弗克违，永贞吉。王用享于帝，吉。"
        },
        "3": {
          "label": "六三",
          "text": "益之用凶事，无咎。有孚中行，告公用圭。"
        },
        "4": {
          "label": "六四",
          "text": "中行，告公从。利用为依迁国。"
        },
        "5": {
          "label": "九五",
          "text": "有孚惠心，勿问元吉。有孚惠我德。"
        },
        "6": {
          "label": "上九",
          "text": "莫益之，或击之，立心勿恒，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/42"
    },
    "43": {
      "number": 43,
      "gua_ci": "扬于王庭，孚号，有厉，告自邑，不利即戎，利有攸往。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "壮于前趾，往不胜为咎。"
        },
        "2": {
          "label": "九二",
          "text": "惕号，莫夜有戎，勿恤。"
        },
        "3": {
          "label": "九三",
          "text": "壮于頄，有凶。君子夬夬，独行遇雨，若濡有愠，无咎。"
        },
        "4": {
          "label": "九四",
          "text": "臀无肤，其行次且。牵羊悔亡，闻言不信。"
        },
        "5": {
          "label": "九五",
          "text": "苋陆夬夬，中行无咎。"
        },
        "6": {
          "label": "上六",
          "text": "无号，终有凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/43"
    },
    "44": {
      "number": 44,
      "gua_ci": "女壮，勿用取女。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "系于金柅，贞吉，有攸往，见凶，羸豕孚蹢躅。"
        },
        "2": {
          "label": "九二",
          "text": "包有鱼，无咎，不利宾。"
        },
        "3": {
          "label": "九三",
          "text": "臀无肤，其行次且，厉，无大咎。"
        },
        "4": {
          "label": "九四",
          "text": "包无鱼，起凶。"
        },
        "5": {
          "label": "九五",
          "text": "以杞包瓜，含章，有陨自天。"
        },
        "6": {
          "label": "上九",
          "text": "姤其角，吝，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/44"
    },
    "45": {
      "number": 45,
      "gua_ci": "亨。王假有庙，利见大人，亨，利贞。用大牲吉，利有攸往。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "有孚不终，乃乱乃萃，若号一握为笑，勿恤，往无咎。"
        },
        "2": {
          "label": "六二",
          "text": "引吉，无咎，孚乃利用禴。"
        },
        "3": {
          "label": "六三",
          "text": "萃如，嗟如，无攸利，往无咎，小吝。"
        },
        "4": {
          "label": "九四",
          "text": "大吉，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "萃有位，无咎。匪孚，元永贞，悔亡。"
        },
        "6": {
          "label": "上六",
          "text": "赍咨涕洟，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/45"
    },
    "46": {
      "number": 46,
      "gua_ci": "元亨，用见大人，勿恤，南征吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "允升，大吉。"
        },
        "2": {
          "label": "九二",
          "text": "孚乃利用禴，无咎。"
        },
        "3": {
          "label": "九三",
          "text": "升虚邑。"
        },
        "4": {
          "label": "六四",
          "text": "王用亨于岐山，吉无咎。"
        },
        "5": {
          "label": "六五",
          "text": "贞吉，升阶。"
        },
        "6": {
          "label": "上六",
          "text": "冥升，利于不息之贞。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/46"
    },
    "47": {
      "number": 47,
      "gua_ci": "亨，贞，大人吉，无咎，有言不信。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "臀困于株木，入于幽谷，三岁不觌。"
        },
        "2": {
          "label": "九二",
          "text": "困于酒食，朱绂方来，利用享祀，征凶，无咎。"
        },
        "3": {
          "label": "六三",
          "text": "困于石，据于蒺蔾，入于其宫，不见其妻，凶。"
        },
        "4": {
          "label": "九四",
          "text": "来徐徐，困于金车，吝，有终。"
        },
        "5": {
          "label": "九五",
          "text": "劓刖，困于赤绂，乃徐有说，利用祭祀。"
        },
        "6": {
          "label": "上六",
          "text": "困于葛藟，于臲卼，曰动悔。有悔，征吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/47"
    },
    "48": {
      "number": 48,
      "gua_ci": "改邑不改井，无丧无得，往来井井。汔至亦未繘井，羸其瓶，凶。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "井泥不食，旧井无禽。"
        },
        "2": {
          "label": "九二",
          "text": "井谷射鲋，瓮敝漏。"
        },
        "3": {
          "label": "九三",
          "text": "井渫不食，为我心恻，可用汲，王明，并受其福。"
        },
        "4": {
          "label": "六四",
          "text": "井甃，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "井洌，寒泉食。"
        },
        "6": {
          "label": "上六",
          "text": "井收勿幕，有孚元吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/48"
    },
    "49": {
      "number": 49,
      "gua_ci": "巳日乃孚，元亨利贞，悔亡。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "巩用黄牛之革。"
        },
        "2": {
          "label": "六二",
          "text": "巳日乃革之，征吉，无咎。"
        },
        "3": {
          "label": "九三",
          "text": "征凶，贞厉，革言三就，有孚。"
        },
        "4": {
          "label": "九四",
          "text": "悔亡，有孚改命，吉。"
        },
        "5": {
          "label": "九五",
          "text": "大人虎变，未占有孚。"
        },
        "6": {
          "label": "上六",
          "text": "君子豹变，小人革面，征凶，居贞吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/49"
    },
    "50": {
      "number": 50,
      "gua_ci": "元吉，亨。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "鼎颠趾，利出否，得妾以其子，无咎。"
        },
        "2": {
          "label": "九二",
          "text": "鼎有实，我仇有疾，不我能即，吉。"
        },
        "3": {
          "label": "九三",
          "text": "鼎耳革，其行塞，雉膏不食，方雨亏悔，终吉。"
        },
        "4": {
          "label": "九四",
          "text": "鼎折足，覆公餗，其形渥，凶。"
        },
        "5": {
          "label": "六五",
          "text": "鼎黄耳，金铉，利贞。"
        },
        "6": {
          "label": "上九",
          "text": "鼎玉铉，大吉，无不利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/50"
    },
    "51": {
      "number": 51,
      "gua_ci": "亨。震来虩虩，笑言哑哑。震惊百里，不丧匕鬯。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "震来虩虩，后笑言哑哑，吉。"
        },
        "2": {
          "label": "六二",
          "text": "震来厉，亿丧贝，跻于九陵，勿逐，七日得。"
        },
        "3": {
          "label": "六三",
          "text": "震苏苏，震行无眚。"
        },
        "4": {
          "label": "九四",
          "text": "震遂泥。"
        },
        "5": {
          "label": "六五",
          "text": "震往来厉，亿无丧，有事。"
        },
        "6": {
          "label": "上六",
          "text": "震索索，视矍矍，征凶。震不于其躬，于其邻，无咎。婚媾有言。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/51"
    },
    "52": {
      "number": 52,
      "gua_ci": "艮其背，不获其身，行其庭，不见其人，无咎。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "艮其趾，无咎，利永贞。"
        },
        "2": {
          "label": "六二",
          "text": "艮其腓，不拯其随，其心不快。"
        },
        "3": {
          "label": "九三",
          "text": "艮其限，列其夤，厉薰心。"
        },
        "4": {
          "label": "六四",
          "text": "艮其身，无咎。"
        },
        "5": {
          "label": "六五",
          "text": "艮其辅，言有序，悔亡。"
        },
        "6": {
          "label": "上九",
          "text": "敦艮，吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/52"
    },
    "53": {
      "number": 53,
      "gua_ci": "女归吉，利贞。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "鸿渐于干，小子厉，有言，无咎。"
        },
        "2": {
          "label": "六二",
          "text": "鸿渐于磐，饮食衎衎，吉。"
        },
        "3": {
          "label": "九三",
          "text": "鸿渐于陆，夫征不复，妇孕不育，凶；利御寇。"
        },
        "4": {
          "label": "六四",
          "text": "鸿渐于木，或得其桷，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "鸿渐于陵，妇三岁不孕，终莫之胜，吉。"
        },
        "6": {
          "label": "上九",
          "text": "鸿渐于逵，其羽可用为仪，吉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/53"
    },
    "54": {
      "number": 54,
      "gua_ci": "征凶，无攸利。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "归妹以娣，跛能履，征吉。"
        },
        "2": {
          "label": "九二",
          "text": "眇能视，利幽人之贞。"
        },
        "3": {
          "label": "六三",
          "text": "归妹以须，反归以娣。"
        },
        "4": {
          "label": "九四",
          "text": "归妹愆期，迟归有时。"
        },
        "5": {
          "label": "六五",
          "text": "帝乙归妹，其君之袂，不如其娣之袂良，月几望，吉。"
        },
        "6": {
          "label": "上六",
          "text": "女承筐无实，士刲羊无血，无攸利。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/54"
    },
    "55": {
      "number": 55,
      "gua_ci": "亨。王假之，勿忧，宜日中。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "遇其配主，虽旬无咎，往有尚。"
        },
        "2": {
          "label": "六二",
          "text": "丰其蔀，日中见斗，往得疑疾，有孚发若，吉。"
        },
        "3": {
          "label": "九三",
          "text": "丰其沛，日中见沫，折其右肱，无咎。"
        },
        "4": {
          "label": "九四",
          "text": "丰其蔀，日中见斗，遇其夷主，吉。"
        },
        "5": {
          "label": "六五",
          "text": "来章，有庆誉，吉。"
        },
        "6": {
          "label": "上六",
          "text": "丰其屋，蔀其家，窥其户，阒其无人，三岁不觌，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/55"
    },
    "56": {
      "number": 56,
      "gua_ci": "小亨，旅贞吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "旅琐琐，斯其所取灾。"
        },
        "2": {
          "label": "六二",
          "text": "旅即次，怀其资，得童仆贞。"
        },
        "3": {
          "label": "九三",
          "text": "旅焚其次，丧其童仆，贞厉。"
        },
        "4": {
          "label": "九四",
          "text": "旅于处，得其资斧，我心不快。"
        },
        "5": {
          "label": "六五",
          "text": "射雉一矢亡，终以誉命。"
        },
        "6": {
          "label": "上九",
          "text": "鸟焚其巢，旅人先笑后号咷。丧牛于易，凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/56"
    },
    "57": {
      "number": 57,
      "gua_ci": "小亨，利有攸往，利见大人。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "进退，利武人之贞。"
        },
        "2": {
          "label": "九二",
          "text": "巽在床下，用史巫纷若，吉无咎。"
        },
        "3": {
          "label": "九三",
          "text": "频巽，吝。"
        },
        "4": {
          "label": "六四",
          "text": "悔亡，田获三品。"
        },
        "5": {
          "label": "九五",
          "text": "贞吉，悔亡，无不利。无初有终，先庚三日，后庚三日，吉。"
        },
        "6": {
          "label": "上九",
          "text": "巽在床下，丧其资斧，贞凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/57"
    },
    "58": {
      "number": 58,
      "gua_ci": "亨，利贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "和兑，吉。"
        },
        "2": {
          "label": "九二",
          "text": "孚兑，吉，悔亡。"
        },
        "3": {
          "label": "六三",
          "text": "来兑，凶。"
        },
        "4": {
          "label": "九四",
          "text": "商兑，未宁，介疾有喜。"
        },
        "5": {
          "label": "九五",
          "text": "孚于剥，有厉。"
        },
        "6": {
          "label": "上六",
          "text": "引兑。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/58"
    },
    "59": {
      "number": 59,
      "gua_ci": "亨。王假有庙，利涉大川，利贞。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "用拯马壮，吉。"
        },
        "2": {
          "label": "九二",
          "text": "涣奔其机，悔亡。"
        },
        "3": {
          "label": "六三",
          "text": "涣其躬，无悔。"
        },
        "4": {
          "label": "六四",
          "text": "涣其群，元吉。涣有丘，匪夷所思。"
        },
        "5": {
          "label": "九五",
          "text": "涣汗其大号，涣王居，无咎。"
        },
        "6": {
          "label": "上九",
          "text": "涣其血，去逖出，无咎。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/59"
    },
    "60": {
      "number": 60,
      "gua_ci": "亨；苦节不可，贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "不出户庭，无咎。"
        },
        "2": {
          "label": "九二",
          "text": "不出门庭，凶。"
        },
        "3": {
          "label": "六三",
          "text": "不节若，则嗟若，无咎。"
        },
        "4": {
          "label": "六四",
          "text": "安节，亨。"
        },
        "5": {
          "label": "九五",
          "text": "甘节，吉，往有尚。"
        },
        "6": {
          "label": "上六",
          "text": "苦节；贞凶，悔亡。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/60"
    },
    "61": {
      "number": 61,
      "gua_ci": "豚鱼吉，利涉大川，利贞。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "虞吉，有它不燕。"
        },
        "2": {
          "label": "九二",
          "text": "鸣鹤在阴，其子和之，我有好爵，吾与尔靡之。"
        },
        "3": {
          "label": "六三",
          "text": "得敌，或鼓或罢，或泣或歌。"
        },
        "4": {
          "label": "六四",
          "text": "月几望，马匹亡，无咎。"
        },
        "5": {
          "label": "九五",
          "text": "有孚挛如，无咎。"
        },
        "6": {
          "label": "上九",
          "text": "翰音登于天，贞凶。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/61"
    },
    "62": {
      "number": 62,
      "gua_ci": "亨，利贞；可小事，不可大事；飞鸟遗之音，不宜上，宜下，大吉。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "飞鸟以凶。"
        },
        "2": {
          "label": "六二",
          "text": "过其祖，遇其妣；不及其君，遇其臣；无咎。"
        },
        "3": {
          "label": "九三",
          "text": "弗过防之，从或戕之，凶。"
        },
        "4": {
          "label": "九四",
          "text": "无咎，弗过遇之；往厉必戒，勿用，永贞。"
        },
        "5": {
          "label": "六五",
          "text": "密云不雨，自我西郊；公弋取彼在穴。"
        },
        "6": {
          "label": "上六",
          "text": "弗遇过之；飞鸟离之，凶，是谓灾眚。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/62"
    },
    "63": {
      "number": 63,
      "gua_ci": "亨小，利贞；初吉终乱。",
      "lines": {
        "1": {
          "label": "初九",
          "text": "曳其轮，濡其尾，无咎。"
        },
        "2": {
          "label": "六二",
          "text": "妇丧其茀，勿逐，七日得。"
        },
        "3": {
          "label": "九三",
          "text": "高宗伐鬼方，三年克之；小人勿用。"
        },
        "4": {
          "label": "六四",
          "text": "繻有衣袽，终日戒。"
        },
        "5": {
          "label": "九五",
          "text": "东邻杀牛，不如西邻之禴祭，实受其福。"
        },
        "6": {
          "label": "上六",
          "text": "濡其首，厉。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/63"
    },
    "64": {
      "number": 64,
      "gua_ci": "亨；小狐汔济，濡其尾，无攸利。",
      "lines": {
        "1": {
          "label": "初六",
          "text": "濡其尾，吝。"
        },
        "2": {
          "label": "九二",
          "text": "曳其轮，贞吉。"
        },
        "3": {
          "label": "六三",
          "text": "未济，征凶，利涉大川。"
        },
        "4": {
          "label": "九四",
          "text": "贞吉，悔亡；震用伐鬼方，三年有赏于大国。"
        },
        "5": {
          "label": "六五",
          "text": "贞吉，无悔；君子之光，有孚吉。"
        },
        "6": {
          "label": "上九",
          "text": "有孚于饮酒，无咎；濡其首，有孚失是。"
        }
      },
      "special": null,
      "source_url": "https://cast64.com/hexagrams/64"
    }
  }
}
